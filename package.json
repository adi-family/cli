{
  "name": "adi-family-cli",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "crates/*/web",
      "plugins/*/web",
      "plugins/*/*/web",
      "apps/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.10",
      "typescript": "~5.9.3",
      "html2canvas": "^1.4.1",
      "lit": "^3.3.2",
      "@tailwindcss/vite": "^4.2.0",
      "@types/node": "^25.3.3",
      "tailwindcss": "^4.2.0",
      "vite": "8.0.0",
      "@open-wc/testing": "^4.0.0",
      "@rollup/plugin-node-resolve": "^16.0.3",
      "@types/mocha": "^10.0.10",
      "@web/dev-server-esbuild": "^1.0.5",
      "@web/test-runner": "^0.20.2",
      "@xterm/xterm": "^6.0.0",
      "@xterm/addon-fit": "^0.11.0",
      "monaco-editor": "^0.55.1"
    }
  },
  "scripts": {
    "test": "bun run --filter '*' test",
    "build": "bun run --filter '@adi-family/*' build",
    "build:all": "bun run build && bun run --filter '*' build"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "dependencies": {}
}
