{
  "name": "@adi-family/cocoon-plugin-interface",
  "version": "0.1.0",
  "description": "Cocoon connection management for ADI web plugins",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:wtr": "web-test-runner"
  },
  "peerDependencies": {},
  "dependencies": {
    "@adi-family/plugin-signaling": "workspace:*",
    "@adi-family/sdk-plugin": "workspace:*",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/bun": "^1.3.10",
    "@types/mocha": "^10.0.10",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "cocoon",
    "plugin",
    "connection",
    "adi"
  ]
}
