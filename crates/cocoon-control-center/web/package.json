{
  "name": "@adi-family/plugin-cocoon-control-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/types.ts",
  "types": "src/types.ts",
  "exports": {
    ".": "./src/types.ts",
    "./build": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir ../../../dist/adi.cocoon-control-center --entry-naming 'web.[ext]' --format esm --minify --external '@adi-family/sdk-plugin' --external 'lit' --external 'lit/*'",
    "typecheck": "tsc --noEmit",
    "dev": "bun build src/index.ts --outdir ../../../dist/adi.cocoon-control-center --entry-naming 'web.[ext]' --format esm --minify --external '@adi-family/sdk-plugin' --external 'lit' --external 'lit/*' --watch"
  },
  "dependencies": {
    "@adi-family/plugin-cocoon": "workspace:*",
    "@adi-family/plugin-signaling": "workspace:*",
    "@adi-family/plugin-router": "workspace:*",
    "@adi-family/plugin-debug-screen": "workspace:*",
    "@adi-family/sdk-plugin": "workspace:*",
    "@xterm/xterm": "catalog:",
    "@xterm/addon-fit": "catalog:",
    "lit": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
