{
  "name": "@adi/credentials-web-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bus": "./src/bus/index.ts"
  },
  "scripts": {
    "generate": "cargo check -p credentials-plugin",
    "generate:protocol": "adi tsp-gen generate ../api.tsp -l typescript -s protocol --protocol-tag type --protocol-rename snake_case --protocol-enum-name CredentialsMessage -o src/generated",
    "build": "npm run generate && npm run generate:protocol && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@adi-family/cocoon-plugin-interface": "file:../../../packages/cocoon-plugin-interface",
    "@adi/router-web-plugin": "file:../../router/web",
    "@adi-family/sdk-plugin": "^0.2.0",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  }
}
