{
  "name": "@adi/router-web-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:events": "tsp-gen ../bus.tsp -l typescript -s eventbus --eventbus-module @adi-family/sdk-plugin/types --eventbus-interface EventRegistry --eventbus-rename kebab-case -o src/generated/bus",
    "generate": "npm run generate:events",
    "build": "npm run generate && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@adi-family/sdk-plugin": "file:../../../packages/plugin-sdk",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  }
}
