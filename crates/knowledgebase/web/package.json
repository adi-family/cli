{
  "name": "@adi/knowledgebase-web-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./bus": "./src/generated/bus/index.ts"
  },
  "scripts": {
    "generate:events": "adi tsp-gen generate ../bus.tsp -l typescript -s eventbus --eventbus-module @adi-family/sdk-plugin/types --eventbus-interface EventRegistry --eventbus-rename kebab-case -o src/generated/bus",
    "build": "npm run generate:events && vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@adi/router-web-plugin": "file:../../router/web",
    "@adi-family/sdk-plugin": "^0.2.0",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  }
}
