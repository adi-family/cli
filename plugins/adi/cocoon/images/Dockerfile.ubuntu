# Cocoon - Ubuntu (Standard)
# Size: ~150MB | Use: Full development environment
# Tools: All Debian tools + Node.js, clang, sudo, more dev tools
#
# Build: docker buildx bake ubuntu
# Run:   docker run -e SIGNALING_SERVER_URL=wss://... git.the-ihor.com/adi/cocoon:ubuntu

# =============================================================================
# Stage 1: Build cocoon binary
# =============================================================================
FROM rust:1.88-alpine AS builder

RUN apk add --no-cache musl-dev openssl-dev openssl-libs-static pkgconfig

WORKDIR /build

# Copy cocoon core source
COPY plugins/adi/cocoon/core/Cargo.toml ./Cargo.toml
COPY plugins/adi/cocoon/core/src ./src
COPY plugins/adi/cocoon/core/build.rs ./build.rs
COPY plugins/adi/cocoon/cocoon.tsp ../cocoon.tsp

# Copy local path dependencies
COPY crates/_lib/lib-adi-service ./crates/_lib/lib-adi-service
COPY crates/_lib/lib-env-parse ./crates/_lib/lib-env-parse
COPY crates/_lib/lib-console-output ./crates/_lib/lib-console-output
COPY packages/theme/generated/themes.rs ./packages/theme/generated/themes.rs
COPY crates/_lib/lib-daemon-client ./crates/_lib/lib-daemon-client
COPY crates/_lib/lib-daemon-core ./crates/_lib/lib-daemon-core
COPY plugins/adi/signaling/protocol ./plugins/adi/signaling/protocol
COPY plugins/adi/signaling/signaling.tsp ./plugins/adi/signaling/signaling.tsp
COPY crates/tsp-gen/core ./crates/tsp-gen/core

# Rewrite path dependencies to match Docker build layout
RUN sed -i 's|path = "../../../../crates/_lib/|path = "./crates/_lib/|g' Cargo.toml && \
    sed -i 's|path = "../../signaling/protocol"|path = "./plugins/adi/signaling/protocol"|g' Cargo.toml && \
    sed -i 's|path = "../../../../crates/tsp-gen/core"|path = "./crates/tsp-gen/core"|g' Cargo.toml

# Remove optional service deps and dev-dependencies (Cargo validates all path deps even if unused)
RUN sed -i '/^tasks-core.*optional.*$/d' Cargo.toml && \
    sed -i '/^tools-core.*optional.*$/d' Cargo.toml && \
    sed -i '/^llm-proxy-core.*optional.*$/d' Cargo.toml && \
    sed -i '/^embed-proxy-core.*optional.*$/d' Cargo.toml && \
    sed -i 's|services = \[.*\]|services = []|g' Cargo.toml && \
    sed -i '/^\[dev-dependencies\]/,$d' Cargo.toml

# Remove workspace inheritance from all local crates
RUN find . -name "Cargo.toml" -exec sed -i \
    -e 's|version\.workspace = true|version = "0.1.0"|g' \
    -e 's|edition\.workspace = true|edition = "2021"|g' \
    -e 's|authors\.workspace = true|authors = ["ADI Team"]|g' \
    -e 's|license\.workspace = true|license = "MIT"|g' \
    {} +

RUN cargo build --release --features standalone

# =============================================================================
# Stage 2: Runtime (Ubuntu)
# =============================================================================
FROM ubuntu:24.04

LABEL org.opencontainers.image.title="Cocoon Ubuntu"
LABEL org.opencontainers.image.description="Full containerized development environment"
LABEL cocoon.variant="ubuntu"
LABEL cocoon.tools="build-essential,python3,nodejs,clang,cmake,git,vim,sudo"

ENV DEBIAN_FRONTEND=noninteractive

# Install comprehensive dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Core utilities
    ca-certificates \
    curl \
    wget \
    git \
    git-lfs \
    jq \
    tar \
    gzip \
    unzip \
    zip \
    xz-utils \
    # Build tools
    build-essential \
    pkg-config \
    cmake \
    ninja-build \
    clang \
    llvm \
    # Python
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    # Node.js (via nodesource would be better, but keeping simple)
    nodejs \
    npm \
    # Editors & tools
    vim \
    nano \
    less \
    htop \
    tree \
    tmux \
    screen \
    # Network tools
    openssh-client \
    rsync \
    netcat-openbsd \
    dnsutils \
    iputils-ping \
    # System
    sudo \
    locales \
    tzdata \
    # Shell
    bash \
    bash-completion \
    zsh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Setup locale
RUN locale-gen en_US.UTF-8

# Copy cocoon binary
COPY --from=builder /build/target/release/cocoon /usr/local/bin/cocoon

# Setup workspace
RUN mkdir -p /cocoon/workspace /cocoon/output
WORKDIR /cocoon/workspace

# Create non-root user with sudo
RUN useradd -m -s /bin/bash -G sudo cocoon && \
    echo "cocoon ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    chown -R cocoon:cocoon /cocoon

# Environment
ENV SIGNALING_SERVER_URL=ws://signaling:8080/ws
ENV COCOON_VARIANT=ubuntu
ENV TERM=xterm-256color
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV TZ=UTC

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD pgrep cocoon || exit 1

CMD ["/usr/local/bin/cocoon"]
