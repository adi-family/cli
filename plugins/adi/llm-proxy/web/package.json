{
  "name": "@adi-family/plugin-llm-proxy",
  "version": "0.8.4",
  "private": true,
  "type": "module",
  "main": "src/types.ts",
  "types": "src/types.ts",
  "exports": {
    ".": "./src/types.ts",
    "./build": "./src/index.ts"
  },
  "scripts": {
    "generate": "cargo check -p llm-proxy-plugin",
    "build": "bun run generate && bun build src/index.ts --outdir ../../../../dist/adi.llm-proxy --entry-naming 'web.[ext]' --format esm --minify --external '@adi-family/sdk-plugin' --external 'lit' --external 'lit/*'",
    "typecheck": "tsc --noEmit",
    "dev": "bun build src/index.ts --outdir ../../../../dist/adi.llm-proxy --entry-naming 'web.[ext]' --format esm --minify --external '@adi-family/sdk-plugin' --external 'lit' --external 'lit/*' --watch"
  },
  "dependencies": {
    "@adi-family/cocoon-plugin-interface": "workspace:*",
    "@adi-family/plugin-cocoon": "workspace:*",
    "@adi-family/plugin-signaling": "workspace:*",
    "@adi-family/plugin-router": "workspace:*",
    "@adi-family/plugin-actions-feed": "workspace:*",
    "@adi-family/sdk-plugin": "workspace:*",
    "lit": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
